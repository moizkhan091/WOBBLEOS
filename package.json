{
  "name": "wobble-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "npm run clean:next-dev-types && next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "next lint",
    "clean:next-dev-types": "node scripts/clean-next-dev-types.mjs",
    "typecheck": "npm run clean:next-dev-types && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run test && npm run build",
    "ci": "npm ci && npm run verify",
    "worker": "tsx src/workers/worker.ts",
    "worker:video": "tsx src/workers/video-worker.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed-runner.ts",
    "library:import": "tsx src/scripts/import-social-library.ts",
    "ask:live-check": "tsx src/scripts/live-ask-check.ts",
    "content:live-check": "tsx src/scripts/live-content-check.ts",
    "skill:live-check": "tsx src/scripts/live-skill-check.ts",
    "memory:backfill-embeddings": "tsx src/scripts/backfill-memory-embeddings.ts",
    "auth:hash": "tsx src/scripts/hash-password.ts",
    "verify:commercial": "tsx src/scripts/verify-commercial-chain-db.ts",
    "verify:consumer": "tsx src/scripts/verify-department-consumer-db.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.42.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "pg-boss": "^12.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
