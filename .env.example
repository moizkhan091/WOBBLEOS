DATABASE_URL=postgres://wobble:change-me@localhost:5432/wobble_os
ASK_WOBBLE_MODEL=openai/gpt-4o-mini
CONTENT_STRATEGY_MODEL=anthropic/claude-sonnet-4.5
SESSION_SECRET=change-me-minimum-32-chars
SHARED_LOGIN_PASSWORD_HASH=$2a$12$replace-with-bcrypt-hash
N8N_WEBHOOK_SECRET=change-me
OPENROUTER_API_KEY=
# Embeddings for semantic memory. Optional: defaults to OPENROUTER_API_KEY +
# openai/text-embedding-3-small (1536 dims). Override only to use a different provider.
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=openai/text-embedding-3-small
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1/embeddings
TAVILY_API_KEY=
FAL_KEY=
WHATSAPP_PROVIDER_KEY=
POSTING_PROVIDER_KEY=
INTERNAL_OS_HOST=os.wobble.local
STORAGE_ROOT=C:\Wobble OS\storage
