DATABASE_URL=postgres://wobble:change-me@localhost:5432/wobble_os
ASK_WOBBLE_MODEL=openai/gpt-4o-mini
CONTENT_STRATEGY_MODEL=anthropic/claude-sonnet-4.5
SESSION_SECRET=change-me-minimum-32-chars
# Founder logins are per-account and live in Postgres — there is NO password in this file.
# After `npm run db:seed`, create the accounts:
#   npm run auth:bootstrap -- --seed-test    # 4 synthetic founders for local work (prints passwords once)
#   npm run auth:bootstrap -- --list
N8N_WEBHOOK_SECRET=change-me
OPENROUTER_API_KEY=
# Embeddings for semantic memory. Optional: defaults to OPENROUTER_API_KEY +
# openai/text-embedding-3-small (1536 dims). Override only to use a different provider.
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=openai/text-embedding-3-small
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1/embeddings
TAVILY_API_KEY=
# DataForSEO keyword/trend data (base64 of "login:password"). Optional — the content engine falls back to
# FREE Google/DDG autocomplete keyword research when absent or the account is unverified.
DATAFORSEO_AUTH=
# GPT-Image-2 is slow (can take ~2 min); the media adapter waits this long (ms). Optional (default 300000).
OPENROUTER_MEDIA_TIMEOUT_MS=300000
FAL_KEY=
WHATSAPP_PROVIDER_KEY=
POSTING_PROVIDER_KEY=
# --- Zernio social publishing (Library & Scheduler) ---
# Leave blank locally: with no key, posting stays manual (nothing fires). Set these on the DEPLOYED
# instance to enable auto post/schedule to Instagram + LinkedIn. Zernio needs PUBLIC_BASE_URL to
# fetch media and to deliver webhooks (it cannot reach localhost). Rotate the key after sharing it.
ZERNIO_API_KEY=
ZERNIO_WEBHOOK_SECRET=
# Public origin of this OS instance, e.g. https://os.wobble.com (no trailing slash). Used to build
# the media URLs Zernio fetches and to receive webhooks at /api/webhooks/zernio.
PUBLIC_BASE_URL=
# Optional: pin the Zernio account id per platform (else resolved from the accounts API).
ZERNIO_ACCOUNT_INSTAGRAM=
ZERNIO_ACCOUNT_LINKEDIN=
# --- Apify scraper (Audit Doc 1: scrape a prospect's website + socials) ---
# Blank locally = scraping skipped, falls back to founder-entered data. Set on the deployed instance
# to auto-pull website/social signals. Optionally override the actor ids.
APIFY_API_KEY=
APIFY_WEBSITE_ACTOR=
APIFY_INSTAGRAM_ACTOR=
INTERNAL_OS_HOST=os.wobble.local
# Where uploaded/generated files live. On a Linux VPS use an absolute Linux path, e.g. /var/lib/wobble-os/storage
STORAGE_ROOT=C:\Wobble OS\storage

# --- Optional model-role overrides (all have sensible defaults in src/db/seed-runner.ts) ---
# Leave blank to use the defaults. Set to pin a specific OpenRouter model per agent role.
DEFAULT_MODEL=
MEMORY_ROUTER_MODEL=
KNOWLEDGE_COMPILER_MODEL=
CONTENT_RESEARCH_MODEL=
CONTENT_COPYWRITING_MODEL=
CONTENT_SCORING_MODEL=
PITCH_WRITER_MODEL=
AUDIT_DISCOVERY_MODEL=
AUDIT_OPPORTUNITY_MODEL=
AUDIT_PRIORITIZATION_MODEL=
AUDIT_ROADMAP_MODEL=
AUDIT_REPORT_MODEL=
AUDIT_INTERVIEW_PLANNER_MODEL=

PLAUSIBLE_API_KEY=

PLAUSIBLE_SITE_ID=

PLAUSIBLE_HOST=

INTELLIGENCE_WEBHOOK_SECRET=

MEDIA_URL_SECRET=
