# WOBBLE OS — production environment template.
# Copy this file OUTSIDE the repository, fill real values, restrict it to the deployment account,
# and pass its absolute path to `bash scripts/deploy.sh /path/to/wobble.env`. NEVER commit the filled file.

# --- Database (the Compose `db` service) ---
POSTGRES_USER=wobble
# [BLOCKED-EXTERNAL] a strong random password:
POSTGRES_PASSWORD=
POSTGRES_DB=wobble_os
# The app + migrate reach the DB over the private Compose network (host = `db`).
# Replace the password below with the SAME value as POSTGRES_PASSWORD:
DATABASE_URL=postgres://wobble:REPLACE_WITH_POSTGRES_PASSWORD@db:5432/wobble_os

# --- Session / auth (REQUIRED) ---
# [BLOCKED-EXTERNAL] 32+ random bytes, e.g. `openssl rand -hex 32`:
SESSION_SECRET=
# NOTE: there is deliberately no password here. Each founder has their own account in Postgres.
# After the migrate + seed step, set each founder's credential on the host (never in this file):
#   npm run auth:bootstrap -- --founder founder_moiz --email moiz@yourdomain.com --super-admin
#   npm run auth:bootstrap -- --founder founder_ali  --email ali@yourdomain.com
# The password is read from stdin (not echoed) or WOBBLE_BOOTSTRAP_PASSWORD, and is never logged.

# --- Public URL / TLS ---
# [BLOCKED-EXTERNAL] public HTTPS origin, with no trailing slash:
PUBLIC_BASE_URL=

# --- Durable storage ---
# Compose mounts the durable volume here. Keep this aligned with docker-compose.prod.yml.
STORAGE_ROOT=/app/storage

# --- Model + tool providers (optional; features degrade honestly when absent) ---
OPENROUTER_API_KEY=
# EMBEDDING_API_KEY=
# FAL_KEY=
# APIFY_API_KEY=
# N8N_WEBHOOK_SECRET=
# Intelligence producers must also send X-Wobble-Producer and X-Wobble-Idempotency-Key; see VPS guide.
# INTELLIGENCE_WEBHOOK_SECRET=
# ZERNIO_WEBHOOK_SECRET=
# MEDIA_URL_SECRET=
