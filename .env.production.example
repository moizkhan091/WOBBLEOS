# WOBBLE OS — production env template. Copy to `.env.production` and fill REAL values. NEVER commit the filled file.
# Items marked [BLOCKED-EXTERNAL] must be supplied by the founder/host — they cannot be generated from this repo.
# IMPORTANT: docker `env_file` keeps everything after `=` as the value — put NO trailing inline comments on a value line.

# --- Database (the compose `db` service) ---
POSTGRES_USER=wobble
# [BLOCKED-EXTERNAL] a strong random password:
POSTGRES_PASSWORD=
POSTGRES_DB=wobble_os
# The app + migrate reach the DB over the private compose network (host = the `db` service name).
# Replace the password below with the SAME value as POSTGRES_PASSWORD:
DATABASE_URL=postgres://wobble:REPLACE_WITH_POSTGRES_PASSWORD@db:5432/wobble_os

# --- Session / auth (REQUIRED) ---
# [BLOCKED-EXTERNAL] 32+ random bytes, e.g. `openssl rand -hex 32`:
SESSION_SECRET=
# [BLOCKED-EXTERNAL] the shared-login password hash: base64 of a bcrypt hash (the app reads *_HASH_B64 so `$` isn't mangled):
SHARED_LOGIN_PASSWORD_HASH_B64=

# --- Public URL / TLS (put a reverse proxy in front; see docs/VPS_DEPLOYMENT.md) ---
# [BLOCKED-EXTERNAL] domain + DNS + TLS. Uncomment + set once the domain exists:
# APP_URL=https://os.yourdomain.com

# --- Model + tool providers (optional; features degrade honestly when absent) ---
# text generation (present in dev). Absent → LLM features degrade, never fabricate:
OPENROUTER_API_KEY=
# embeddings for retrieval (optional):
# EMBEDDING_API_KEY=
# [BLOCKED-EXTERNAL] real media generation (Media Studio stays 'blocked' without it):
# FAL_KEY=
# rich social/web scraping (ingestion falls back to the unblocked http/inline adapters):
# APIFY_API_KEY=
# signed n8n handoff (optional):
# N8N_WEBHOOK_SECRET=
