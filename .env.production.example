# WOBBLE OS — production environment template.
# Copy this file OUTSIDE the repository, fill real values, restrict it to the deployment account,
# and pass its absolute path to `bash scripts/deploy.sh /path/to/wobble.env`. NEVER commit the filled file.
#
# Every variable production code reads is listed here (enforced by tests/prod-env-template.test.ts —
# a new production env var that is not documented here fails CI). Commented-out vars are OPTIONAL:
# the feature they gate degrades honestly (blocked/inert, never faked) while they are absent.

# --- Database (the Compose `db` service) ---
POSTGRES_USER=wobble
# [BLOCKED-EXTERNAL] a strong random password:
POSTGRES_PASSWORD=
POSTGRES_DB=wobble_os
# The app + migrate reach the DB over the private Compose network (host = `db`).
# Replace the password below with the SAME value as POSTGRES_PASSWORD:
DATABASE_URL=postgres://wobble:REPLACE_WITH_POSTGRES_PASSWORD@db:5432/wobble_os

# --- Session / auth (REQUIRED) ---
# [BLOCKED-EXTERNAL] 32+ random bytes, e.g. `openssl rand -hex 32`:
SESSION_SECRET=
# NOTE: there is deliberately no password here. Each founder has their own account in Postgres.
# After the migrate + seed step, set each founder's credential on the host (never in this file):
#   npm run auth:bootstrap -- --founder founder_moiz --email moiz@yourdomain.com --super-admin
#   npm run auth:bootstrap -- --founder founder_ali  --email ali@yourdomain.com
# The password is read from stdin (not echoed) or WOBBLE_BOOTSTRAP_PASSWORD, and is never logged.

# --- Public URL / TLS ---
# [BLOCKED-EXTERNAL] public HTTPS origin, with no trailing slash:
PUBLIC_BASE_URL=

# --- Durable storage ---
# Compose mounts the durable volume here. Keep this aligned with docker-compose.prod.yml.
STORAGE_ROOT=/app/storage
# Signs public media URLs (unguessable links). 32+ random bytes, e.g. `openssl rand -hex 32`:
MEDIA_URL_SECRET=
# Optional allowlist for POST /api/library/import-folder, which bulk-imports a server-side content
# folder. `;`- or `,`-separated absolute directories; the requested root must resolve inside one of
# them. LEAVE EMPTY on a single-founder machine (any absolute directory is then allowed, still behind
# the founder session gate); SET IT on a shared/hosted deployment so the importer can only ever read
# the content volume, e.g. LIBRARY_IMPORT_ROOTS=/app/storage/import
LIBRARY_IMPORT_ROOTS=

# --- The LLM brain (REQUIRED for anything AI, including Media Studio images) ---
# OpenRouter powers ALL text roles AND Media Studio image generation — no FAL needed for images.
OPENROUTER_API_KEY=
# GPT-Image-class models can take ~2 min; how long the media adapter waits (ms; default 300000):
# OPENROUTER_MEDIA_TIMEOUT_MS=300000

# --- Optional providers (each gates one capability; absent → that capability reports blocked) ---
# Vector memory embeddings:
# EMBEDDING_API_KEY=
# fal.ai — VIDEO / AUDIO / 3D media kinds ONLY (images run on OpenRouter above):
# FAL_KEY=
# Apify web/social scraping + Competitor Scout. CANONICAL name is APIFY_API_TOKEN
# (legacy alias APIFY_API_KEY is still accepted, but new deploys should use the canonical name):
# APIFY_API_TOKEN=
# Tavily research search:
# TAVILY_API_KEY=
# ElevenLabs voice synthesis:
# ELEVENLABS_API_KEY=
# DataForSEO keyword/trend data ("login:password" basic-auth pair):
# DATAFORSEO_AUTH=
# Zernio social auto-posting (both needed):
# ZERNIO_API_KEY=
# ZERNIO_WEBHOOK_SECRET=
# n8n automation handoff (HMAC secret shared with your n8n instance):
# N8N_WEBHOOK_SECRET=
# Intelligence ingestion webhook (producers must also send X-Wobble-Producer + X-Wobble-Idempotency-Key):
# INTELLIGENCE_WEBHOOK_SECRET=
# Plausible website analytics (both key + site id needed; host only for self-hosted Plausible):
# PLAUSIBLE_API_KEY=
# PLAUSIBLE_SITE_ID=
# PLAUSIBLE_HOST=https://plausible.io
